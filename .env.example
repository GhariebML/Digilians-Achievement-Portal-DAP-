# Digilians Competition Tracker Platform - Environment Configuration

# Google Sheets Integration (Preferred Option)
# URL to your deployed Google Apps Script Web App (pointing to Code.gs)
VITE_GOOGLE_SHEETS_API_URL=https://script.google.com/macros/s/AKfycbw_SAMPLE_ID/exec

# Supabase Database (Alternative Option)
# Your Supabase Project URL and Anon Key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Master Data Storage Mode (Can be toggled live in Admin settings between: 'local', 'google-sheets', 'supabase')
VITE_DEFAULT_STORAGE_MODE=supabase
